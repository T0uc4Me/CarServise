{
  "env": {
    "node": true,
    "es2021": true,
    "browser": false
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "error",
    "semi": ["warn", "always"],
    "eqeqeq": ["warn", "always"],
    "no-var": "warn"
  },
  "ignorePatterns": ["node_modules/", "public/", "views/"]
}
