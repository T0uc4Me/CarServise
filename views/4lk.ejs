<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/1style.css" />
    <title>Личный кабинет | Car Service</title>
    <style>
        /* Specific Dashboard Styles requiring no extra CSS file */
        .dashboard-container {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 40px;
            margin-top: 40px;
            min-height: 80vh;
        }

        .sidebar {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 30px;
            height: fit-content;
            text-align: center;
        }

        .profile-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            margin-bottom: 20px;
            padding: 10px;
        }

        .profile-name {
            font-size: 1.2rem;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .profile-phone-box {
            background: rgba(0,0,0,0.2);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 30px;
            font-family: monospace;
            font-size: 1.1rem;
            color: var(--text-muted);
        }

        .dashboard-main {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .section-title {
            font-family: var(--font-display);
            font-size: 2rem;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--glass-border);
            padding-bottom: 10px;
        }

        .cars-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .car-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            padding: 20px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .car-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,0.08);
        }

        .car-icon {
            width: 50px;
            height: 50px;
            background: var(--accent-color);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #0f0e17;
        }

        .car-info strong {
            display: block;
            font-size: 1.1rem;
        }

        .car-info span {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .car-actions {
            margin-left: auto;
            display: flex;
            gap: 10px;
        }

        .car-action-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            font-size: 1.2rem;
            padding: 0;
        }

        .car-action-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.1);
        }

        .car-action-btn.edit:hover {
            border-color: var(--accent-color);
            box-shadow: 0 0 10px rgba(255, 174, 82, 0.2);
        }

        .car-action-btn.delete:hover {
            border-color: #ff4d4d;
            box-shadow: 0 0 10px rgba(255, 77, 77, 0.2);
        }

        .add-car-btn {
            background: transparent;
            border: 2px dashed var(--glass-border);
            border-radius: 15px;
            color: var(--text-muted);
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            height: 100%;
            min-height: 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .add-car-btn:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: rgba(255, 174, 82, 0.05);
        }

        .back-link {
            position: absolute;
            top: 20px;
            left: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        
        .back-link:hover {
            color: var(--text-color);
        }

        @media (max-width: 768px) {
            .dashboard-container {
                grid-template-columns: 1fr;
            }
        }
    </style>
  </head>
  <body>
    <!-- Back Link -->
    <a href="/" class="back-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        На главную
    </a>

    <div class="container dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <img src="/img/svg/acc_logo.svg" alt="Profile" class="profile-img" onerror="this.src='https://ui-avatars.com/api/?name=User&background=random'" />
            <h2 class="profile-name"><%= fio %></h2>
            
            <div class="info-card">
                <div class="info-label">Телефон</div>
                <div class="info-value"><%= phone %></div>
            </div>

            <div class="info-card">
                <div class="info-label">Email</div>
                <div class="info-value"><%= email %></div>
            </div>

            <div class="info-card">
                <div class="info-label">Дата регистрации</div>
                <div class="info-value"><%= date %></div>
            </div>

            <div class="info-card highlight-card">
                <div class="info-label">Общая стоимость заказов</div>
                <div class="info-value"><%= cost %> ₽</div>
            </div>
            
            <a href="/auth/logout" class="btn btn-login logout-btn">Выйти</a>
        </aside>

        <!-- Main Content -->
        <main class="dashboard-main">
            <section>
                <h1 class="section-title">Ваши автомобили</h1>
                <div class="cars-grid">
                    <!-- Car Cards -->
                    <% cars.forEach(car => { %>
                    <div class="car-card">
                        <div class="car-icon">🚗</div>
                        <div class="car-info">
                            <strong><%= car.mark %></strong>
                            <span><%= car.model %></span>
                        </div>
                        <div class="car-actions">
                            <a href="/car/edit/<%= car.car_id %>" class="car-action-btn edit" title="Редактировать">✏️</a>
                            <form action="/car/delete/<%= car.car_id %>" method="POST" onsubmit="return confirm('Удалить этот автомобиль?')">
                                <button type="submit" class="car-action-btn delete" title="Удалить">🗑️</button>
                            </form>
                        </div>
                    </div>
                    <% }); %>
                    
                    <!-- Add Car Button -->
                    <form action="/car" method="GET" style="display: contents;">
                        <button type="submit" class="add-car-btn">
                            <span style="font-size: 2rem;">+</span>
                            <span>Добавить авто</span>
                        </button>
                    </form>
                </div>
            </section>
            <section style="margin-top: 40px;">
                <h1 class="section-title">История заказов</h1>
                <div class="orders-history">
                    <% if (typeof orders !== 'undefined' && orders && orders.length > 0) { %>
                        <div class="orders-table-wrapper">
                            <table class="orders-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Дата</th>
                                        <th>Сумма</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach(order => { %>
                                    <tr>
                                        <td>#<%= order.order_id %></td>
                                        <td><%= order.servis_data %></td>
                                        <td class="order-amount"><%= order.total_amount %> ₽</td>
                                        <td>
                                            <span class="status-badge <%= order.order_status === 'active' ? 'status-active' : 'status-closed' %>">
                                                <%= order.order_status === 'active' ? 'В работе' : 'Завершен' %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-history">
                            <p>У вас пока нет заказов.</p>
                            <a href="/zakaz" class="btn btn-cta" style="padding: 10px 20px; font-size: 0.9rem; margin-top:15px;">Сделать первый заказ</a>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

    <style>
        /* Extra styles inline for quick adjustment, can move to 1style.css later */
        .info-card {
            background: rgba(0,0,0,0.2);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 15px;
            text-align: left;
        }

        .highlight-card {
            background: rgba(255, 174, 82, 0.1);
            border: 1px solid var(--accent-color);
        }

        .info-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .info-value {
            font-family: monospace;
            font-size: 1rem;
            word-break: break-all;
        }

        .logout-btn {
            width: 100%; 
            margin-top: 20px;
            box-sizing: border-box; /* Fixes overflow issue */
            display: flex; /* Ensures text centering */
            justify-content: center;
        }

        .orders-table-wrapper {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            overflow: hidden;
            margin-top: 20px;
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .orders-table th, .orders-table td {
            padding: 15px 20px;
            border-bottom: 1px solid var(--glass-border);
        }

        .orders-table th {
            background: rgba(255, 255, 255, 0.03);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .order-amount {
            color: var(--accent-color);
            font-weight: 700;
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .status-active {
            background: rgba(108, 99, 255, 0.2);
            color: #6C63FF;
            border: 1px solid rgba(108, 99, 255, 0.3);
        }

        .status-closed {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid rgba(40, 167, 69, 0.3);
        }

        .empty-history {
            text-align: center;
            padding: 40px;
            background: rgba(255,255,255,0.02);
            border: 1px dashed var(--glass-border);
            border-radius: 15px;
            color: var(--text-muted);
        }
    </style>

    <!-- Scripts -->
    <script src="/js/a1.js"></script>

    <!-- ===== CHAT WIDGET ===== -->
    <div class="chat-widget" id="chatWidget">
        <div class="chat-window" id="chatWindow">
            <div class="chat-header">
                <div class="chat-header-avatar">🛠️</div>
                <div class="chat-header-info">
                    <div class="chat-header-name">Администрация</div>
                    <div class="chat-header-status">Онлайн</div>
                </div>
            </div>
            <div class="chat-messages" id="chatMessages">
                <div class="chat-empty" id="chatEmpty">
                    💬 Напишите нам — мы ответим в ближайшее время!
                </div>
            </div>
            <div class="chat-input-area">
                <textarea class="chat-input" id="chatInput" placeholder="Введите сообщение..." rows="1"></textarea>
                <button class="chat-send-btn" id="chatSendBtn" title="Отправить">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
        </div>

        <button class="chat-toggle-btn" id="chatToggle" title="Чат с поддержкой">
            <span id="chatIcon">💬</span>
            <span class="chat-badge" id="chatBadge">0</span>
        </button>
    </div>

    <script>
    (function() {
        const toggle   = document.getElementById('chatToggle');
        const window_  = document.getElementById('chatWindow');
        const messages = document.getElementById('chatMessages');
        const input    = document.getElementById('chatInput');
        const sendBtn  = document.getElementById('chatSendBtn');
        const badge    = document.getElementById('chatBadge');
        const empty    = document.getElementById('chatEmpty');

        let isOpen = false;
        let lastId = 0;
        let pollTimer = null;

        // --- helpers ---
        function formatTime(dt) {
            const d = new Date(dt);
            return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
        }

        function appendMsg(msg) {
            if (empty) empty.remove();
            const wrap = document.createElement('div');
            wrap.className = 'chat-message ' + (msg.sender === 'user' ? 'user' : 'admin');
            wrap.innerHTML = `<div>${escapeHtml(msg.message)}</div><div class="chat-message-time">${formatTime(msg.created_at || new Date())}</div>`;
            messages.appendChild(wrap);
            messages.scrollTop = messages.scrollHeight;
            if (msg.id > lastId) lastId = msg.id;
        }

        function escapeHtml(text) {
            return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }

        // --- load all messages ---
        function loadMessages(markRead) {
            fetch('/chat/messages?since=0')
                .then(r => r.json())
                .then(msgs => {
                    if (!Array.isArray(msgs)) return;
                    msgs.forEach(m => { appendMsg(m); });
                    if (markRead) markAsRead();
                    checkUnread();
                })
                .catch(() => {});
        }

        // --- poll new messages ---
        function pollMessages() {
            fetch('/chat/messages?since=' + lastId)
                .then(r => r.json())
                .then(msgs => {
                    if (!Array.isArray(msgs)) return;
                    msgs.filter(m => m.id > lastId).forEach(m => {
                        appendMsg(m);
                        if (!isOpen && m.sender === 'admin') showBadge();
                    });
                    if (isOpen && msgs.some(m => m.sender === 'admin')) markAsRead();
                })
                .catch(() => {});
        }

        function markAsRead() {
            fetch('/chat/read', { method: 'POST' }).catch(() => {});
            badge.classList.remove('visible');
        }

        function checkUnread() {
            fetch('/chat/unread-count')
                .then(r => r.json())
                .then(data => {
                    if (data.count > 0) showBadge(data.count);
                })
                .catch(() => {});
        }

        function showBadge(n) {
            badge.textContent = n || '!';
            badge.classList.add('visible');
        }

        // --- open / close ---
        toggle.addEventListener('click', () => {
            isOpen = !isOpen;
            if (isOpen) {
                window_.classList.add('open');
                badge.classList.remove('visible');
                if (lastId === 0) loadMessages(true);
                else markAsRead();
                pollTimer = setInterval(pollMessages, 3000);
            } else {
                window_.classList.remove('open');
                clearInterval(pollTimer);
            }
        });

        // --- send ---
        function sendMessage() {
            const text = input.value.trim();
            if (!text) return;
            input.value = '';
            input.style.height = 'auto';

            fetch('/chat/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            })
            .then(r => r.json())
            .then(msg => {
                if (msg.id) appendMsg({ ...msg, created_at: new Date().toISOString() });
            })
            .catch(() => {});
        }

        sendBtn.addEventListener('click', sendMessage);
        input.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
        });

        // auto-resize textarea
        input.addEventListener('input', () => {
            input.style.height = 'auto';
            input.style.height = Math.min(input.scrollHeight, 100) + 'px';
        });

        // initial badge check
        checkUnread();
        setInterval(checkUnread, 15000);
    })();
    </script>
  </body>
</html>
