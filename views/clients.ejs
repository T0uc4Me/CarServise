<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/1style.css" />
    <title>Наши клиенты | Car Service</title>
    <style>
        .clients-hero {
            padding: 80px 0 40px;
            text-align: center;
        }

        .clients-intro {
            max-width: 800px;
            margin: 0 auto 60px;
            text-align: center;
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .clients-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 80px;
        }

        .client-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .client-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary-color);
            box-shadow: 0 20px 40px rgba(108, 99, 255, 0.15);
        }

        .client-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 1.5rem;
            color: white;
            margin-bottom: 20px;
            border: 4px solid rgba(255, 255, 255, 0.1);
        }

        .client-name {
            font-family: var(--font-display);
            font-size: 1.2rem;
            margin-bottom: 10px;
            color: var(--text-color);
        }

        .client-car {
            font-size: 0.85rem;
            color: var(--primary-color);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .client-feedback {
            font-style: italic;
            color: var(--text-muted);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .partners-section {
            margin-top: 60px;
            text-align: center;
        }

        .partners-title {
            font-family: var(--font-display);
            font-size: 1.5rem;
            margin-bottom: 40px;
        }

        .partners-logos {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
            gap: 50px;
            opacity: 0.6;
        }

        .partner-logo {
            height: 40px;
            filter: grayscale(100%) invert(1);
            transition: var(--transition);
        }

        .partner-logo:hover {
            filter: grayscale(0%) invert(0);
            opacity: 1;
        }
    </style>
</head>

<body>
    <header class="header container">
        <div class="header-left">
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Меню" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="/" class="logo-container">
                <img src="/img/svg/Logo.svg" alt="Car Service Logo" class="logo-img" />
                <div class="logo-text">Car Service</div>
            </a>
        </div>
        <div class="auth-buttons">
            <% if (isLoggedIn) { %>
                <a href="/account" class="btn btn-login">Личный кабинет</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-login">Войти</a>
                    <a href="/auth/reg" class="btn btn-register">Регистрация</a>
                    <% } %>
        </div>
    </header>

    <main class="container">
        <section class="clients-hero">
            <h1 class="hero-title">Наши <span class="highlight">Клиенты</span></h1>
        </section>

        <p class="clients-intro">
            Мы гордимся тем, что нам доверяют сотни автовладельцев. Каждый клиент для нас — это история долгого сотрудничества, основанного на качестве и доверии.
        </p>

        <div class="clients-grid">
            <div class="client-card">
                <div class="client-avatar">АИ</div>
                <h3 class="client-name">Александр Иванов</h3>
                <span class="client-car">BMW X5 M</span>
                <p class="client-feedback">"Пользуюсь услугами заправки и ТО уже год. Всегда вовремя, топливо отличное. Очень удобно, что не нужно никуда ехать."</p>
            </div>

            <div class="client-card">
                <div class="client-avatar">МС</div>
                <h3 class="client-name">Марина Соколова</h3>
                <span class="client-car">Tesla Model 3</span>
                <p class="client-feedback">"Приезжаю на детейлинг только сюда. Мастера знают толк в бережном уходе. Машина после них как из салона!"</p>
            </div>

            <div class="client-card">
                <div class="client-avatar">ДП</div>
                <h3 class="client-name">Дмитрий Петров</h3>
                <span class="client-car">Audi RS6</span>
                <p class="client-feedback">"Быстро поменяли резину и сделали диагностику. Цены адекватные, сервис на высоте. Рекомендую всем знакомым."</p>
            </div>

            <div class="client-card">
                <div class="client-avatar">ЕЛ</div>
                <h3 class="client-name">Елена Лазарева</h3>
                <span class="client-car">Porsche Cayenne</span>
                <p class="client-feedback">"Сервис, который действительно экономит время. Заказала заправку прямо на парковку у офиса — очень удобно."</p>
            </div>
        </div>

        <section class="partners-section">
            <h2 class="partners-title">Нам доверяют</h2>
            <div class="partners-logos">
                <img src="/img/svg/Logo.svg" alt="Partner 1" class="partner-logo" />
                <img src="/img/svg/acc_logo.svg" alt="Partner 2" class="partner-logo" />
                <img src="/img/svg/footerlogo.svg" alt="Partner 3" class="partner-logo" />
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container footer-content">
            <div class="footer-col">
                <div class="logo-container" style="margin-bottom:20px;">
                    <img src="/img/svg/Logo.svg" alt="Logo" style="height:30px;" />
                    <span style="font-family:var(--font-display);margin-left:10px;">Car Service</span>
                </div>
                <p>ООО "КИПУ"</p>
                <p>ИНН 9709075179</p>
                <p>ОГРН 1217700488763</p>
            </div>
            <div class="footer-col">
                <h3>Контакты</h3>
                <p>+7 (978) 978 79 78</p>
                <p>sewspot@bk.ru</p>
            </div>
            <div class="footer-col">
                <h3>Информация</h3>
                <div class="footer-links">
                    <a href="/services">Услуги</a>
                    <a href="/clients">Наши клиенты</a>
                    <a href="/about">О нас</a>
                </div>
            </div>
            <div class="footer-col">
                <h3>Мы в соцсетях</h3>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- OVERLAY & SIDE NAV -->
    <div class="nav-overlay" id="navOverlay"></div>
    <nav class="side-nav" id="sideNav" aria-hidden="true">
        <div class="side-nav-address">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            Симферополь ул.Толстого 52
        </div>
        <div class="side-nav-logo">
            <img src="/img/svg/Logo.svg" alt="Car Service Logo" />
            <span class="side-nav-logo-text">Car Service</span>
        </div>
        <button class="side-nav-close" id="sideNavClose" aria-label="Закрыть меню">&times;</button>
        <div class="side-nav-links">
            <a href="/services" class="side-nav-link">
                <span class="nav-icon">🔧</span>
                Услуги
            </a>
            <a href="/clients" class="side-nav-link">
                <span class="nav-icon">👥</span>
                Наши клиенты
            </a>
            <a href="/about" class="side-nav-link">
                <span class="nav-icon">ℹ️</span>
                О нас
            </a>
            <div style="margin-top: auto; padding: 25px; border-top: 1px solid var(--glass-border);">
                <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">Мы в соцсетях</div>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <script>
        (function() {
            const btn = document.getElementById('hamburgerBtn');
            const nav = document.getElementById('sideNav');
            const overlay = document.getElementById('navOverlay');
            const closeBtn = document.getElementById('sideNavClose');

            function openNav() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('visible');
                document.body.style.overflow = 'hidden';
            }

            function closeNav() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('visible');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', () => nav.classList.contains('open') ? closeNav() : openNav());
            closeBtn.addEventListener('click', closeNav);
            overlay.addEventListener('click', closeNav);
        })();
    </script>
</body>

</html>
