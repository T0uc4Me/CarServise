<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/1style.css" />
    <title>О нас | Car Service</title>
    <style>
        .about-hero {
            padding: 80px 0 40px;
            text-align: center;
        }

        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            margin-bottom: 100px;
        }

        .about-text-content {
            z-index: 1;
        }

        .about-heading {
            font-family: var(--font-display);
            font-size: 2.5rem;
            margin-bottom: 25px;
            line-height: 1.3;
        }

        .about-description {
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1.8;
            margin-bottom: 30px;
        }

        .about-image-wrapper {
            position: relative;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
            border: 1px solid var(--glass-border);
        }

        .about-image-wrapper img {
            width: 100%;
            display: block;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 40px;
        }

        .stat-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            padding: 20px;
            border-radius: 20px;
            text-align: center;
        }

        .stat-number {
            display: block;
            font-family: var(--font-display);
            font-size: 1.8rem;
            color: var(--accent-color);
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        @media (max-width: 900px) {
            .about-content {
                grid-template-columns: 1fr;
                gap: 40px;
            }
        }
    </style>
</head>

<body>
    <header class="header container">
        <div class="header-left">
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Меню" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="/" class="logo-container">
                <img src="/img/svg/Logo.svg" alt="Car Service Logo" class="logo-img" />
                <div class="logo-text">Car Service</div>
            </a>
        </div>
        <div class="auth-buttons">
            <% if (isLoggedIn) { %>
                <a href="/account" class="btn btn-login">Личный кабинет</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-login">Войти</a>
                    <a href="/auth/reg" class="btn btn-register">Регистрация</a>
                    <% } %>
        </div>
    </header>

    <main class="container">
        <section class="about-hero">
            <h1 class="hero-title">О <span class="highlight">Нас</span></h1>
        </section>

        <section class="about-content">
            <div class="about-text-content">
                <h2 class="about-heading">Выездной сервис <br /><span class="highlight">вашего комфорта</span>
                </h2>
                <p class="about-description">
                    <strong>Car Service</strong> — это профессиональное обслуживание автомобиля там, где удобно вам. 
                    Забудьте о поездках в сервис и очередях: наши мастера приедут по адресу и выполнят работу на месте.
                </p>
                <p class="about-description">
                    Мы предлагаем всё необходимое: от экспресс-заправки топливом и замены масла до комплексной диагностики 
                    и детейлинга. Просто выберите услугу на сайте, и мы позаботимся о вашем авто.
                </p>
                <p class="about-description">
                    Наша миссия — сделать уход за машиной быстрым, легким и технологичным.
                </p>

                <div class="stats-grid">
                    <div class="stat-card">
                        <span class="stat-number">500+</span>
                        <span class="stat-label">Клиентов</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number">10+</span>
                        <span class="stat-label">Услуг</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number">5 лет</span>
                        <span class="stat-label">Опыта</span>
                    </div>
                </div>
            </div>

            <div class="about-image-wrapper">
                <img src="/img/cool_mechanics_about.png" alt="Профессиональные механики" />
            </div>
        </section>
    </main>

    <footer class="footer">
        <!-- Footer content (same as services) -->
        <div class="container footer-content">
            <div class="footer-col">
                <div class="logo-container" style="margin-bottom:20px;">
                    <img src="/img/svg/Logo.svg" alt="Logo" style="height:30px;" />
                    <span style="font-family:var(--font-display);margin-left:10px;">Car Service</span>
                </div>
                <p>ООО "КИПУ"</p>
                <p>ИНН 9709075179</p>
                <p>ОГРН 1217700488763</p>
            </div>
            <div class="footer-col">
                <h3>Контакты</h3>
                <p>+7 (978) 978 79 78</p>
                <p>sewspot@bk.ru</p>
            </div>
            <div class="footer-col">
                <h3>Информация</h3>
                <div class="footer-links">
                    <a href="/services">Услуги</a>
                    <a href="/clients">Наши клиенты</a>
                    <a href="/about">О нас</a>
                </div>
            </div>
            <div class="footer-col">
                <h3>Мы в соцсетях</h3>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg"
                            alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg"
                            alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- OVERLAY & SIDE NAV -->
    <div class="nav-overlay" id="navOverlay"></div>
    <nav class="side-nav" id="sideNav" aria-hidden="true">
        <div class="side-nav-address">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
            </svg>
            Симферополь ул.Толстого 52
        </div>
        <div class="side-nav-logo">
            <img src="/img/svg/Logo.svg" alt="Car Service Logo" />
            <span class="side-nav-logo-text">Car Service</span>
        </div>
        <button class="side-nav-close" id="sideNavClose" aria-label="Закрыть меню">&times;</button>
        <div class="side-nav-links">
            <a href="/services" class="side-nav-link">
                <span class="nav-icon">🔧</span>
                Услуги
            </a>
            <a href="/clients" class="side-nav-link">
                <span class="nav-icon">👥</span>
                Наши клиенты
            </a>
            <a href="/about" class="side-nav-link">
                <span class="nav-icon">ℹ️</span>
                О нас
            </a>
            <div style="margin-top: auto; padding: 25px; border-top: 1px solid var(--glass-border);">
                <div
                    style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">
                    Мы в соцсетях</div>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg"
                            alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg"
                            alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <script>
        (function () {
            const btn = document.getElementById('hamburgerBtn');
            const nav = document.getElementById('sideNav');
            const overlay = document.getElementById('navOverlay');
            const closeBtn = document.getElementById('sideNavClose');

            function openNav() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('visible');
                document.body.style.overflow = 'hidden';
            }

            function closeNav() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('visible');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', () => nav.classList.contains('open') ? closeNav() : openNav());
            closeBtn.addEventListener('click', closeNav);
            overlay.addEventListener('click', closeNav);
        })();
    </script>
</body>

</html>