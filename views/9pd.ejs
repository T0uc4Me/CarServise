<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/1style.css" />
    <title>Car Service | Оформление заказа</title>
  </head>
  <body>
    <header class="header container">
        <div class="logo-container">
            <a href="/home2" style="display: flex; align-items: center; gap: 15px;">
                <img src="/img/svg/Logo.svg" alt="Car Service Logo" class="logo-img" />
                <div class="logo-text">Car Service</div>
            </a>
        </div>
        <div class="auth-buttons">
            <a href="/account" class="btn btn-login">Личный кабинет</a>
            <a href="/auth/logout" class="btn btn-register" style="background: transparent; border: 1px solid var(--glass-border);">Выйти</a>
        </div>
    </header>

    <main class="container">
      <section class="order-section">
        <div class="order-container">
          <% if (typeof successMessage !== "undefined") { %>
            <div class="success-message">
              <p><%= successMessage %></p>
            </div>
          <% } %>
          
          <form id="order-form" method="POST" action="/zakaz">
            <h2>Оформление заказа</h2>
            
            <div class="form-group">
                <label for="fio">ФИО:</label>
                <input
                  type="text"
                  id="fio"
                  name="fio"
                  placeholder="Иванов Иван Иванович"
                  readonly
                  value="<%= fio %>"
                />
            </div>
    
            <div class="form-group">
                <label for="car">Автомобиль:</label>
                <% if (cars && cars.length > 0) { %>
                    <select id="car" name="carId" required>
                      <% cars.forEach(car => { %>
                      <option value="<%= car.car_id %>">
                        <%= car.mark %> <%= car.model %>
                      </option>
                      <% }); %>
                    </select>
                <% } else { %>
                    <div class="no-cars-container">
                        <select id="car" name="carId" required disabled>
                            <option value="">Нет доступных авто</option>
                        </select>
                        <a href="/car" class="add-car-btn">
                            <span class="plus-icon">+</span> Добавить автомобиль
                        </a>
                    </div>
                <% } %>
            </div>
    
            <div class="form-group">
                <label for="address">Адрес:</label>
                <input
                  type="text"
                  id="address"
                  name="address"
                  placeholder="Введите адрес"
                  required
                />
            </div>
    
            <div class="form-group">
                <label for="services">Услуги:</label>
                <div class="services-groups">
                  <div class="service-category">
                    <h3>Заправка топливом</h3>
                    <div class="service-options">
                      <% services.filter(s => s.servis_type === 'Заправка' || s.servis_name.toLowerCase().includes('заправка')).forEach(service => { %>
                      <label class="service-label fuel-option">
                        <input
                          type="checkbox"
                          name="services[]"
                          value="<%= service.servis_id %>"
                          class="service-checkbox"
                          data-price="<%= service.servis_price %>"
                        />
                        <div class="service-content">
                          <div class="service-header">
                            <span class="service-name"><%= service.servis_name.replace('Заправка ', '') %></span>
                            <span class="service-price"><%= service.servis_price %> ₽/л</span>
                          </div>
                          <div class="quantity-wrapper" style="display: none">
                            <div class="quantity-controls">
                              <button type="button" class="quantity-btn minus">-</button>
                              <input
                                type="number"
                                name="quantity_<%= service.servis_id %>"
                                class="quantity-input fuel-quantity"
                                value="1000"
                                min="100"
                                step="100"
                                data-price-per-liter="<%= service.servis_price %>"
                              />
                              <button type="button" class="quantity-btn plus">+</button>
                            </div>
                            <span class="quantity-unit">₽</span>
                            <span class="liters-calc">(≈ 0 л.)</span>
                          </div>
                        </div>
                      </label>
                      <% }); %>
                    </div>
                  </div>

                  <div class="service-category">
                    <h3>Техническое обслуживание и ремонт</h3>
                    <div class="service-options">
                      <% services.filter(s => s.servis_type !== 'Заправка' && !s.servis_name.toLowerCase().includes('заправка')).forEach(service => { %>
                      <label class="service-label">
                        <input
                          type="checkbox"
                          name="services[]"
                          value="<%= service.servis_id %>"
                          class="service-checkbox"
                          data-price="<%= service.servis_price %>"
                        />
                        <div class="service-content">
                          <div class="service-header">
                            <span class="service-name"><%= service.servis_name %></span>
                            <span class="service-price"><%= service.servis_price %> ₽</span>
                          </div>
                          <% if (service.servis_name.toLowerCase().includes('колеса') || service.servis_name.toLowerCase().includes('шина')) { %>
                          <div class="quantity-wrapper" style="display: none">
                            <div class="quantity-controls">
                              <button type="button" class="quantity-btn minus">-</button>
                              <input
                                type="number"
                                name="quantity_<%= service.servis_id %>"
                                class="quantity-input"
                                value="1"
                                min="1"
                                max="100"
                              />
                              <button type="button" class="quantity-btn plus">+</button>
                            </div>
                            <span class="quantity-unit">шт.</span>
                          </div>
                          <% } %>
                        </div>
                      </label>
                      <% }); %>
                    </div>
                  </div>
                </div>
            </div>

            <div class="form-group">
                <label for="payment_method">Способ оплаты:</label>
                <select id="payment_method" name="payment_method" required>
                  <option value="card">Карта</option>
                  <option value="cash">Наличные</option>
                  <option value="online">Онлайн-оплата</option>
                </select>
            </div>

            <div class="total-container">
              <div class="total-price-container">
                <span>Итого:</span>
                <span id="total-price">0 ₽</span>
              </div>
            </div>
            <input type="hidden" name="total_amount" id="total_amount" />
    
            <div class="form-group">
                <label for="additional">Дополнительные требования:</label>
                <textarea id="additional" name="additionalRequirements"></textarea>
            </div>
    
            <button type="submit">Оформить заказ</button>
          </form>
        </div>
      </section>
    </main>
    
    <footer class="footer">
        <div class="container footer-content">
            <div class="footer-col">
                <div class="logo-container" style="margin-bottom: 20px;">
                    <img src="/img/svg/Logo.svg" alt="Logo" style="height: 30px;" />
                     <span style="font-family: var(--font-display); margin-left:10px;">Car Service</span>
                </div>
                <p>ООО "КИПУ"</p>
                <p>ИНН 9709075179</p>
                <p>ОГРН 1217700488763</p>
            </div>
            
            <div class="footer-col">
                <h3>Контакты</h3>
                <p>+7 (978) 978 79 78</p>
                <p>sewspot@bk.ru</p>
            </div>

            <div class="footer-col">
                <h3>Информация</h3>
                <div class="footer-links">
                    <a href="#">Заказчикам</a>
                    <a href="#">Исполнителям</a>
                    <a href="#">Тарифы</a>
                    <a href="#">О нас</a>
                </div>
            </div>

            <div class="footer-col">
                <h3>Мы в соцсетях</h3>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
                    <a href="https://www.youtube.com/" class="social-icon"><img src="/img/svg/Ytube.svg" alt="YouTube" /></a>
                </div>
            </div>
        </div>
    </footer>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const checkboxes = document.querySelectorAll(".service-checkbox");
        const totalPriceElement = document.getElementById("total-price");
        const totalAmountElement = document.getElementById("total_amount");

        function updateTotalPrice() {
          let totalPrice = 0;
          checkboxes.forEach((checkbox) => {
            if (checkbox.checked) {
              const label = checkbox.closest("label");
              const quantityInput = label.querySelector(".quantity-input");
              const price = parseFloat(checkbox.getAttribute("data-price"));
              const quantity = quantityInput ? parseFloat(quantityInput.value) : 1;
              
              if (label.classList.contains('fuel-option')) {
                // Для топлива quantity - это уже сумма в рублях
                totalPrice += quantity;
                
                // Обновляем расчет литров
                const litersSpan = label.querySelector('.liters-calc');
                if (litersSpan) {
                  const liters = (quantity / price).toFixed(2);
                  litersSpan.textContent = `(≈ ${liters} л.)`;
                }
              } else {
                totalPrice += price * quantity;
              }
            }
          });

          totalPriceElement.textContent = `${totalPrice.toLocaleString('ru-RU')} ₽`;
          totalAmountElement.value = totalPrice;
        }

        checkboxes.forEach((checkbox) => {
          checkbox.addEventListener("change", function () {
            const label = this.closest("label");
            if (this.checked) {
              label.classList.add("checked");
              const quantityWrapper = label.querySelector(".quantity-wrapper");
              if (quantityWrapper) quantityWrapper.style.display = "block";
            } else {
              label.classList.remove("checked");
              const quantityWrapper = label.querySelector(".quantity-wrapper");
              if (quantityWrapper) quantityWrapper.style.display = "none";
            }
            updateTotalPrice();
          });
        });

        document.querySelectorAll(".quantity-btn").forEach((btn) => {
          btn.addEventListener("click", function (e) {
            e.preventDefault();
            const input = this.closest(".quantity-controls").querySelector(".quantity-input");
            let value = parseInt(input.value);
            const step = input.classList.contains('fuel-quantity') ? 100 : 1;
            
            if (this.classList.contains("minus")) {
              value = Math.max(parseInt(input.getAttribute('min') || 1), value - step);
            } else if (this.classList.contains("plus")) {
              value = value + step;
            }
            input.value = value;
            updateTotalPrice();
          });
        });

        // Also listen to direct input changes
        document.querySelectorAll('.quantity-input').forEach(input => {
          input.addEventListener('input', updateTotalPrice);
        });

        updateTotalPrice();
      });
    </script>
  </body>
</html>
