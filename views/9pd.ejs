<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/1style.css" />
  <title>Car Service | Оформление заказа</title>
</head>

<body>
  <header class="header container">
    <div class="header-left">
      <button class="hamburger-btn" id="hamburgerBtn" aria-label="Меню" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <a href="/" class="logo-container">
        <img src="/img/svg/Logo.svg" alt="Car Service Logo" class="logo-img" />
        <div class="logo-text">Car Service</div>
      </a>
    </div>
    <div class="auth-buttons">
      <a href="/account" class="btn btn-login">Личный кабинет</a>
      <a href="/auth/logout" class="btn btn-register"
        style="background: transparent; border: 1px solid var(--glass-border);">Выйти</a>
    </div>
  </header>

  <main class="container">
    <section class="order-section">
      <div class="order-container">
        <% if (typeof successMessage !=="undefined" ) { %>
          <div class="success-message success-premium">
            <div class="success-icon">✓</div>
            <h3>
              <%= successMessage %>
            </h3>
            <p>Ваш заказ передан в работу</p>
            <div style="margin-top: 25px; display: flex; gap: 15px; justify-content: center;">
              <a href="/" class="btn-cta" style="font-size: 0.9rem; padding: 12px 30px;">На главную</a>
              <a href="/account" class="btn" style="border: 1px solid var(--glass-border); font-size: 0.9rem;">В личный
                кабинет</a>
            </div>
          </div>
          <% } else { %>
            <form id="order-form" method="POST" action="/zakaz">
              <h2>Оформление заказа</h2>

              <div class="form-group">
                <label for="fio">ФИО:</label>
                <input type="text" id="fio" name="fio" placeholder="Иванов Иван Иванович" readonly value="<%= fio %>" />
              </div>

              <div class="form-group">
                <label for="car">Автомобиль:</label>
                <% if (cars && cars.length> 0) { %>
                  <select id="car" name="carId" required>
                    <% cars.forEach(car=> { %>
                      <option value="<%= car.car_id %>">
                        <%= car.mark %>
                          <%= car.model %>
                      </option>
                      <% }); %>
                  </select>
                  <% } else { %>
                    <div class="no-cars-container">
                      <select id="car" name="carId" required disabled>
                        <option value="">Нет доступных авто</option>
                      </select>
                      <a href="/car" class="add-car-btn">
                        <span class="plus-icon">+</span> Добавить автомобиль
                      </a>
                    </div>
                    <% } %>
              </div>

              <div class="form-group">
                <label for="address">Адрес:</label>
                <input type="text" id="address" name="address" placeholder="Введите адрес" required />
              </div>

              <div class="form-group">
                <label for="services">Услуги:</label>
                <div class="services-groups">
                  <div class="service-category">
                    <h3>Бензин</h3>
                    <div class="service-options">
                      <% services.filter(s=> s.servis_type === 'Заправка').forEach(service => { %>
                        <label class="service-label fuel-option">
                          <input type="checkbox" name="services[]" value="<%= service.servis_id %>"
                            class="service-checkbox" data-price="<%= service.servis_price %>" />
                          <div class="service-content">
                            <div class="service-header">
                              <span class="service-name">
                                <%= service.servis_name.replace('Заправка ', '') %></span>
                              <span class="service-price"><%= service.servis_price %> ₽/л</span>
                            </div>
                            <div class="quantity-wrapper" style="display: none">
                              <div class="quantity-controls">
                                <button type="button" class="quantity-btn minus">-</button>
                                <div class="currency-input-wrapper">
                                  <input
                                    type="number"
                                    name="quantity_<%= service.servis_id %>"
                                    class="quantity-input fuel-quantity"
                                    value="1000"
                                    min="100"
                                    step="100"
                                    data-price-per-liter="<%= service.servis_price %>"
                                  />
                                  <span class="currency-symbol-inside">₽</span>
                                </div>
                                <button type="button" class="quantity-btn plus">+</button>
                              </div>
                              <span class="liters-calc">(<span>≈ 0 л.</span>)</span>
                            </div>
                          </div>
                        </label>
                        <% }); %>
                      </div>
                    </div>
  
                    <div class="service-category">
                      <h3>Работа с жидкостями</h3>
                      <div class="service-options">
                        <% services.filter(s => s.servis_type.trim() === 'Жидкости').forEach(service=> { %>
                                  <label class="service-label fuel-option">
                                    <input type="checkbox" name="services[]" value="<%= service.servis_id %>"
                                      class="service-checkbox" data-price="<%= service.servis_price %>" />
                                    <div class="service-content">
                                      <div class="service-header">
                                        <span class="service-name">
                                          <%= service.servis_name %>
                                        </span>
                                        <% let unit='л' ; if (service.servis_name.toLowerCase().includes('кондиционер'))
                                          unit='усл.' ; %>
                                          <span class="service-price">
                                            <%= service.servis_price %> ₽/<%= unit %>
                                          </span>
                                      </div>
                                      <div class="quantity-wrapper" style="display: none">
                                        <div class="quantity-controls">
                                          <button type="button" class="quantity-btn minus">-</button>
                                          <div class="currency-input-wrapper">
                                            <% let defaultVal=500; let minVal=service.servis_price; let stepVal=100; 
                                              if (service.servis_name.toLowerCase().includes('кондиционер')) {
                                                defaultVal=service.servis_price; stepVal=service.servis_price; 
                                              } else if (service.servis_name.toLowerCase().includes('омыв')) {
                                                minVal = 0; stepVal = 50; defaultVal = 100;
                                              } %>
                                              <input type="number" name="quantity_<%= service.servis_id %>"
                                                class="quantity-input fuel-quantity" value="<%= defaultVal %>"
                                                min="<%= minVal %>" step="<%= stepVal %>"
                                                data-price-per-liter="<%= service.servis_price %>" />
                                              <span class="currency-symbol-inside">₽</span>
                                          </div>
                                          <button type="button" class="quantity-btn plus">+</button>
                                        </div>
                                        <% let fuelUnit='л.' ; if
                                          (service.servis_name.toLowerCase().includes('кондиционер')) fuelUnit='усл.' ;
                                          %>
                                          <span class="liters-calc">(<span>≈ 0 <%= fuelUnit %></span>)</span>
                                      </div>
                                    </div>
                                  </label>
                                  <% }); %>
                            </div>
                          </div>

                          <div class="service-category">
                            <h3>Техническое обслуживание и ремонт</h3>
                            <div class="service-options">
                              <% services.filter(s=> s.servis_type !== 'Заправка' && s.servis_type !==
                                'Жидкости').forEach(service => { %>
                                <label class="service-label">
                                  <input type="checkbox" name="services[]" value="<%= service.servis_id %>"
                                    class="service-checkbox" data-price="<%= service.servis_price %>" />
                                  <div class="service-content">
                                    <div class="service-header">
                                      <span class="service-name">
                                        <%= service.servis_name %>
                                      </span>
                                      <span class="service-price">
                                        <%= service.servis_price %> ₽
                                      </span>
                                    </div>
                                    <% if (service.servis_name.toLowerCase().includes('колеса') ||
                                      service.servis_name.toLowerCase().includes('шина')) { %>
                                      <div class="quantity-wrapper" style="display: none">
                                        <div class="quantity-controls">
                                          <button type="button" class="quantity-btn minus">-</button>
                                          <input type="number" name="quantity_<%= service.servis_id %>"
                                            class="quantity-input" value="1" min="1" max="100" />
                                          <button type="button" class="quantity-btn plus">+</button>
                                        </div>
                                        <span class="quantity-unit">шт.</span>
                                      </div>
                                      <% } %>
                                  </div>
                                </label>
                                <% }); %>
                            </div>
                          </div>
                    </div>
                  </div>

                  <div class="form-group">
                    <label for="payment_method">Способ оплаты:</label>
                    <select id="payment_method" name="payment_method" required>
                      <option value="card">Карта</option>
                      <option value="cash">Наличные</option>
                      <option value="online">Онлайн-оплата</option>
                    </select>
                  </div>

                  <div class="total-container">
                    <div class="total-price-container">
                      <span>Итого к оплате:</span>
                      <span id="total-price">0 ₽</span>
                    </div>
                  </div>
                  <input type="hidden" name="total_amount" id="total_amount" />

                  <div class="form-group">
                    <label for="additional">Дополнительные требования (необязательно):</label>
                    <textarea id="additional" name="additionalRequirements"
                      placeholder="Например: удобное время для звонка..."></textarea>
                  </div>

                  <button type="submit" class="btn-cta" style="width: 100%;" id="submit-order-btn">Оформить
                    заказ</button>
            </form>
            <% } %>
      </div>
    </section>
  </main>

  <footer class="footer">
    <!-- Footer content remains the same ... -->
    <div class="container footer-content">
      <div class="footer-col">
        <div class="logo-container" style="margin-bottom: 20px;">
          <img src="/img/svg/Logo.svg" alt="Logo" style="height: 30px;" />
          <span style="font-family: var(--font-display); margin-left:10px;">Car Service</span>
        </div>
        <p>ООО "КИПУ"</p>
        <p>ИНН 9709075179</p>
        <p>ОГРН 1217700488763</p>
      </div>

      <div class="footer-col">
        <h3>Контакты</h3>
        <p>+7 (978) 978 79 78</p>
        <p>sewspot@bk.ru</p>
      </div>

      <div class="footer-col">
        <h3>Информация</h3>
        <div class="footer-links">
          <a href="/services">Услуги</a>
          <a href="/clients">Наши клиенты</a>
          <a href="/about">О нас</a>
        </div>
      </div>

      <div class="footer-col">
        <h3>Мы в соцсетях</h3>
        <div class="social-links">
          <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
          <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
          <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
          <a href="https://instagram.com" class="social-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <!-- OVERLAY & SIDE NAV -->
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="side-nav" id="sideNav" aria-hidden="true">
    <div class="side-nav-address">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      Симферополь ул.Толстого 52
    </div>
    <div class="side-nav-logo">
      <img src="/img/svg/Logo.svg" alt="Car Service Logo" />
      <span class="side-nav-logo-text">Car Service</span>
    </div>
    <button class="side-nav-close" id="sideNavClose" aria-label="Закрыть меню">&times;</button>
    <div class="side-nav-links">
      <a href="/services" class="side-nav-link">
        <span class="nav-icon">🔧</span>
        Услуги
      </a>
      <a href="/clients" class="side-nav-link">
        <span class="nav-icon">👥</span>
        Наши клиенты
      </a>
      <a href="/about" class="side-nav-link">
        <span class="nav-icon">ℹ️</span>
        О нас
      </a>
      <div style="margin-top: auto; padding: 25px; border-top: 1px solid var(--glass-border);">
        <div
          style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">
          Мы в соцсетях</div>
        <div class="social-links">
          <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
          <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
          <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
          <a href="https://instagram.com" class="social-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      console.log("DOM loaded, initializing scripts...");

      const form = document.getElementById("order-form");
      const submitBtn = document.getElementById("submit-order-btn");
      const carSelect = document.getElementById("car");
      const checkboxes = document.querySelectorAll(".service-checkbox");
      const totalPriceElement = document.getElementById("total-price");
      const totalAmountElement = document.getElementById("total_amount");

      if (!form || !submitBtn) {
        console.log("Form or submit button not found (possibly already submitted)");
        return;
      }

      function updateTotalPrice() {
        try {
          let totalPrice = 0;
          checkboxes.forEach((checkbox) => {
            if (checkbox.checked) {
              const label = checkbox.closest("label");
              const quantityInput = label.querySelector(".quantity-input");
              const price = parseFloat(checkbox.getAttribute("data-price")) || 0;
              const quantity = quantityInput ? parseFloat(quantityInput.value) : 1;

              if (label.classList.contains('fuel-option')) {
                totalPrice += quantity;
                const litersSpan = label.querySelector('.liters-calc span');
                if (litersSpan) {
                  const liters = price > 0 ? (quantity / price).toFixed(2) : 0;
                  litersSpan.textContent = `≈ ${liters} ${litersSpan.textContent.split(' ').pop()}`;
                }
              } else {
                totalPrice += price * quantity;
              }
            }
          });

          if (totalPriceElement) totalPriceElement.textContent = `${totalPrice.toLocaleString('ru-RU')} ₽`;
          if (totalAmountElement) totalAmountElement.value = totalPrice;

          const hasCars = carSelect && !carSelect.disabled && carSelect.value;
          const hasServices = Array.from(checkboxes).some(c => c.checked);

          // Instead of disabling, we can just visually dim if needed, but let's keep it functional
          // and check logic on submit to avoid "stuck" buttons
          if (totalPrice <= 0 || !hasCars || !hasServices) {
            submitBtn.classList.add('btn-disabled');
          } else {
            submitBtn.classList.remove('btn-disabled');
          }
        } catch (e) {
          console.error("Error in updateTotalPrice:", e);
        }
      }

      checkboxes.forEach((checkbox) => {
        checkbox.addEventListener("change", function () {
          const label = this.closest("label");
          if (this.checked) {
            label.classList.add("checked");
            const qw = label.querySelector(".quantity-wrapper");
            if (qw) qw.style.display = "block";
          } else {
            label.classList.remove("checked");
            const qw = label.querySelector(".quantity-wrapper");
            if (qw) qw.style.display = "none";
          }
          updateTotalPrice();
        });
      });

      document.querySelectorAll(".quantity-btn").forEach((btn) => {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          const input = this.closest(".quantity-controls").querySelector(".quantity-input");
          let value = parseFloat(input.value) || 0;
          let step = 1;

          if (input.classList.contains('fuel-quantity')) {
            const label = this.closest('label');
            const name = label.querySelector('.service-name').textContent.toLowerCase();
            const isAC = name.includes('кондиционер');
            const isOmyv = name.includes('омыв');
            const servicePrice = parseFloat(label.querySelector('.service-checkbox').getAttribute('data-price')) || 1;
            step = isAC ? servicePrice : (isOmyv ? 50 : 100);
          }

          if (this.classList.contains("minus")) {
            let minAttr = parseFloat(input.getAttribute('min'));
            if (isNaN(minAttr)) minAttr = 1;
            value = Math.max(minAttr, value - step);
          } else {
            value = value + step;
          }
          input.value = value;
          updateTotalPrice();
        });
      });

      document.querySelectorAll('.quantity-input').forEach(input => {
        input.addEventListener('input', updateTotalPrice);
      });

      form.addEventListener("submit", function (e) {
        const hasCars = carSelect && !carSelect.disabled && carSelect.value;
        const hasServices = Array.from(checkboxes).some(c => c.checked);

        if (!hasCars) {
          e.preventDefault();
          alert("Пожалуйста, выберите автомобиль.");
          return;
        }
        if (!hasServices) {
          e.preventDefault();
          alert("Пожалуйста, выберите хотя бы одну услугу.");
          return;
        }

        submitBtn.innerHTML = "<span>Оформление...</span>";
        submitBtn.style.opacity = "0.7";
        submitBtn.style.pointerEvents = "none";
      });

      // Side Nav Logic
      const hBtn = document.getElementById('hamburgerBtn');
      const sNav = document.getElementById('sideNav');
      const sOverlay = document.getElementById('navOverlay');
      const sCloseBtn = document.getElementById('sideNavClose');

      if (hBtn && sNav && sOverlay) {
        const toggleSNav = (open) => {
          hBtn.classList.toggle('open', open);
          sNav.classList.toggle('open', open);
          sOverlay.classList.toggle('visible', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        hBtn.onclick = () => toggleSNav(!sNav.classList.contains('open'));
        if (sCloseBtn) sCloseBtn.onclick = () => toggleSNav(false);
        sOverlay.onclick = () => toggleSNav(false);
      }

      updateTotalPrice();
    });
  </script>
</body>

</html>