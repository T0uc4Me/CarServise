<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/1style.css" />
    <title>Наши услуги | Car Service</title>
    <style>
        .services-hero {
            padding: 100px 0 60px;
            text-align: center;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 30px;
            margin-bottom: 80px;
        }

        .service-full-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            overflow: hidden;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }

        .service-full-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary-color);
            box-shadow: 0 20px 40px rgba(108, 99, 255, 0.2);
        }

        .service-img-wrapper {
            width: 100%;
            height: 220px;
            overflow: hidden;
        }

        .service-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .service-full-card:hover .service-img-wrapper img {
            transform: scale(1.1);
        }

        .service-body {
            padding: 30px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .service-tag {
            display: inline-block;
            padding: 4px 12px;
            background: rgba(108, 99, 255, 0.1);
            color: var(--primary-color);
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .service-title {
            font-family: var(--font-display);
            font-size: 1.4rem;
            margin-bottom: 15px;
            color: var(--text-color);
        }

        .service-text {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 25px;
            flex: 1;
        }

        .service-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 20px;
            border-top: 1px solid var(--glass-border);
        }

        .service-price-tag {
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--accent-color);
        }
    </style>
</head>

<body>
    <header class="header container">
        <div class="header-left">
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Меню" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="/" class="logo-container">
                <img src="/img/svg/Logo.svg" alt="Car Service Logo" class="logo-img" />
                <div class="logo-text">Car Service</div>
            </a>
        </div>
        <div class="auth-buttons">
            <% if (isLoggedIn) { %>
                <a href="/account" class="btn btn-login">Личный кабинет</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-login">Войти</a>
                    <a href="/auth/reg" class="btn btn-register">Регистрация</a>
                    <% } %>
        </div>
    </header>

    <main class="container">
        <section class="services-hero">
            <h1 class="hero-title">Наши <span class="highlight">Услуги</span></h1>
            <p class="carousel-subtitle">Профессиональное обслуживание вашего автомобиля с гарантией качества</p>
        </section>

        <div class="services-grid">
            <!-- Услуга 1 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/fuel.png" alt="Заправка топлива">
                </div>
                <div class="service-body">
                    <span class="service-tag">Топливо</span>
                    <h2 class="service-title">Выездная заправка</h2>
                    <p class="service-text">Мы привезем качественное топливо (АИ-92, АИ-95, ДТ) прямо к вашему автомобилю. Вам не нужно тратить время на очереди на АЗС.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 52 ₽/л</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 2 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/maintenance.png" alt="ТО">
                </div>
                <div class="service-body">
                    <span class="service-tag">Сервис</span>
                    <h2 class="service-title">Замена свечей и фильтров</h2>
                    <p class="service-text">Комплексная замена расходных материалов: масляных, воздушных и салонных фильтров, а также свечей зажигания для стабильной работы двигателя.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 800 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 3 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/tires.png" alt="Шиномонтаж">
                </div>
                <div class="service-body">
                    <span class="service-tag">Колеса</span>
                    <h2 class="service-title">Шиномонтаж</h2>
                    <p class="service-text">Сезонная смена шин, балансировка и ремонт проколов. Быстро и аккуратно на профессиональном оборудовании.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 800 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 4 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/detailing.jpg" alt="Детейлинг">
                </div>
                <div class="service-body">
                    <span class="service-tag">Уход</span>
                    <h2 class="service-title">Детейлинг салона</h2>
                    <p class="service-text">Глубокая химчистка, полировка элементов интерьера и нанесение защитных покрытий для сохранения новизны салона.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 5 000 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 5 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/battery.jpg" alt="АКБ">
                </div>
                <div class="service-body">
                    <span class="service-tag">Электрика</span>
                    <h2 class="service-title">Замена аккумулятора</h2>
                    <p class="service-text">Проверка состояния вашей АКБ и установка новой с гарантией. Бесплатная утилизация старого аккумулятора.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 500 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 6 -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/diagnostics.jpg" alt="Диагностика">
                </div>
                <div class="service-body">
                    <span class="service-tag">Диагностика</span>
                    <h2 class="service-title">Компьютерная диагностика</h2>
                    <p class="service-text">Полное сканирование электронных систем автомобиля, выявление и сброс ошибок, профессиональная консультация мастера.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 1 500 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 7 (Key Repair) -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <!-- Assuming we don't have key.jpg, I'll use a placeholder or something related -->
                    <img src="/img/maintenance.png" alt="Ключи">
                </div>
                <div class="service-body">
                    <span class="service-tag">Ремонт</span>
                    <h2 class="service-title">Ремонт ключа зажигания</h2>
                    <p class="service-text">Замена кнопок, корпуса, батареек или перепрошивка чипа ключа зажигания. Изготовление дубликатов.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 1 200 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>

            <!-- Услуга 8 (Roadside Assistance) -->
            <div class="service-full-card">
                <div class="service-img-wrapper">
                    <img src="/img/fuel.png" alt="Дорожная помощь">
                </div>
                <div class="service-body">
                    <span class="service-tag">Срочно</span>
                    <h2 class="service-title">СРАЗУ НА ДОРОГЕ</h2>
                    <p class="service-text">Экстренная заправка кондиционера, доливка антифриза или омывающей жидкости прямо на месте стоянки вашего авто.</p>
                    <div class="service-footer">
                        <span class="service-price-tag">от 300 ₽</span>
                        <a href="/zakaz" class="btn btn-login" style="padding: 8px 16px; border-radius: 12px;">Заказать</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container footer-content">
            <div class="footer-col">
                <div class="logo-container" style="margin-bottom:20px;">
                    <img src="/img/svg/Logo.svg" alt="Logo" style="height:30px;" />
                    <span style="font-family:var(--font-display);margin-left:10px;">Car Service</span>
                </div>
                <p>ООО "КИПУ"</p>
                <p>ИНН 9709075179</p>
                <p>ОГРН 1217700488763</p>
            </div>
            <div class="footer-col">
                <h3>Контакты</h3>
                <p>+7 (978) 978 79 78</p>
                <p>sewspot@bk.ru</p>
            </div>
            <div class="footer-col">
                <h3>Информация</h3>
                <div class="footer-links">
                    <a href="/services">Услуги</a>
                    <a href="/clients">Наши клиенты</a>
                    <a href="/about">О нас</a>
                </div>
            </div>
            <div class="footer-col">
                <h3>Мы в соцсетях</h3>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- OVERLAY & SIDE NAV (Copy from index) -->
    <div class="nav-overlay" id="navOverlay"></div>
    <nav class="side-nav" id="sideNav" aria-hidden="true">
        <div class="side-nav-address">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            Симферополь ул.Толстого 52
        </div>
        <div class="side-nav-logo">
            <img src="/img/svg/Logo.svg" alt="Car Service Logo" />
            <span class="side-nav-logo-text">Car Service</span>
        </div>
        <button class="side-nav-close" id="sideNavClose" aria-label="Закрыть меню">&times;</button>
        <div class="side-nav-links">
            <a href="/services" class="side-nav-link">
                <span class="nav-icon">🔧</span>
                Услуги
            </a>
            <a href="/clients" class="side-nav-link">
                <span class="nav-icon">👥</span>
                Наши клиенты
            </a>
            <a href="/about" class="side-nav-link">
                <span class="nav-icon">ℹ️</span>
                О нас
            </a>
            <div style="margin-top: auto; padding: 25px; border-top: 1px solid var(--glass-border);">
                <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">Мы в соцсетях</div>
                <div class="social-links">
                    <a href="https://vk.com" class="social-icon"><img src="/img/svg/Vk.svg" alt="Vk" /></a>
                    <a href="https://web.telegram.org" class="social-icon"><img src="/img/svg/Tg.svg" alt="Telegram" /></a>
                    <a href="https://web.whatsapp.com/" class="social-icon"><img src="/img/svg/WhatsAap.svg" alt="WhatsAap" /></a>
                    <a href="https://instagram.com" class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <script>
        (function() {
            const btn = document.getElementById('hamburgerBtn');
            const nav = document.getElementById('sideNav');
            const overlay = document.getElementById('navOverlay');
            const closeBtn = document.getElementById('sideNavClose');

            function openNav() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('visible');
                document.body.style.overflow = 'hidden';
            }

            function closeNav() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('visible');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', () => nav.classList.contains('open') ? closeNav() : openNav());
            closeBtn.addEventListener('click', closeNav);
            overlay.addEventListener('click', closeNav);
        })();
    </script>
</body>

</html>
