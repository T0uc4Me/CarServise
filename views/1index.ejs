    <!-- ===== CHAT WIDGET (только для авторизованных) ===== -->
    <% if (isLoggedIn) { %>
        <div class="chat-widget" id="chatWidget">
            <div class="chat-window" id="chatWindow">
                <div class="chat-header">
                    <div class="chat-header-avatar">🛠️</div>
                    <div class="chat-header-info">
                        <div class="chat-header-name">Администрация</div>
                        <div class="chat-header-status">Онлайн</div>
                    </div>
                </div>
                <div class="chat-messages" id="chatMessages">
                    <div class="chat-empty" id="chatEmpty">💬 Напишите нам — мы ответим в ближайшее время!</div>
                </div>
                <div class="chat-input-area">
                    <textarea class="chat-input" id="chatInput" placeholder="Введите сообщение..." rows="1"></textarea>
                    <button class="chat-send-btn" id="chatSendBtn" title="Отправить">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                    </button>
                </div>
            </div>
            <button class="chat-toggle-btn" id="chatToggle" title="Чат с поддержкой">
                <span>💬</span>
                <span class="chat-badge" id="chatBadge"></span>
            </button>
        </div>

        <script>
            (function () {
                const toggle = document.getElementById('chatToggle');
                const winEl = document.getElementById('chatWindow');
                const messages = document.getElementById('chatMessages');
                const input = document.getElementById('chatInput');
                const sendBtn = document.getElementById('chatSendBtn');
                const badge = document.getElementById('chatBadge');
                let empty = document.getElementById('chatEmpty');
                let isOpen = false, lastId = 0, pollTimer = null;

                function fmt(dt) { return new Date(dt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }); }
                function esc(t) { return t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

                function appendMsg(msg) {
                    if (empty) { empty.remove(); empty = null; }
                    const d = document.createElement('div');
                    d.className = 'chat-message ' + (msg.sender === 'user' ? 'user' : 'admin');
                    d.innerHTML = `<div>${esc(msg.message)}</div><div class="chat-message-time">${fmt(msg.created_at || new Date())}</div>`;
                    messages.appendChild(d);
                    messages.scrollTop = messages.scrollHeight;
                    if (msg.id > lastId) lastId = msg.id;
                }

                function load() {
                    fetch('/chat/messages?since=0')
                        .then(r => r.ok ? r.json() : [])
                        .then(msgs => { if (Array.isArray(msgs)) msgs.forEach(appendMsg); markRead(); })
                        .catch(() => { });
                }

                function poll() {
                    fetch('/chat/messages?since=' + lastId)
                        .then(r => r.ok ? r.json() : [])
                        .then(msgs => {
                            if (!Array.isArray(msgs)) return;
                            msgs.filter(m => m.id > lastId).forEach(m => {
                                appendMsg(m);
                                if (!isOpen && m.sender === 'admin') showBadge();
                            });
                            if (isOpen) markRead();
                        }).catch(() => { });
                }

                function markRead() { fetch('/chat/read', { method: 'POST' }).catch(() => { }); badge.classList.remove('visible'); }
                function showBadge() { badge.textContent = '!'; badge.classList.add('visible'); }

                function checkUnread() {
                    fetch('/chat/unread-count').then(r => r.ok ? r.json() : { count: 0 })
                        .then(d => { if (d.count > 0) showBadge(); }).catch(() => { });
                }

                toggle.addEventListener('click', () => {
                    isOpen = !isOpen;
                    if (isOpen) {
                        winEl.classList.add('open');
                        if (lastId === 0) load(); else markRead();
                        pollTimer = setInterval(poll, 3000);
                    } else {
                        winEl.classList.remove('open');
                        clearInterval(pollTimer);
                    }
                });

                function send() {
                    const text = input.value.trim(); if (!text) return;
                    input.value = ''; input.style.height = 'auto';
                    fetch('/chat/send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: text }) })
                        .then(r => r.ok ? r.json() : {})
                        .then(msg => { if (msg.id) appendMsg({ ...msg, created_at: new Date().toISOString() }); })
                        .catch(() => { });
                }

                sendBtn.addEventListener('click', send);
                input.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
                input.addEventListener('input', () => { input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 100) + 'px'; });

                checkUnread();
                setInterval(checkUnread, 15000);
            })();
        </script>
        <% } %>

            <script src="/js/a1.js"></script>

