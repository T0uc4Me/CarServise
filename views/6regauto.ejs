<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Krona+One&family=Unbounded:wght@200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/6style.css"> 
    <link rel="stylesheet" href="/css/footer.css"> 
    <title>Регистрация автомобиля | Car Service</title>
</head>
<body>
  <header class="page-header">
    <a href="/account"><img src="/img/svg/Logo.svg" alt="logo" class="Logo"></a>
    <a href="/account" class="lk">Личный кабинет</a>
  </header>

  <main class="big_container">
    <div class="container">
      <div class="registration__auto">
        <h2 class="h2"><%= (typeof car !== 'undefined' && car) ? 'Редактирование' : 'Регистрация' %> автомобиля</h2>

        <% if (locals.error) { %>
          <div class="feedback error"><%= error %></div>
        <% } %>

        <% if (locals.success) { %>
          <div class="feedback success"><%= success %></div>
        <% } %>

        <form action="<%= (typeof car !== 'undefined' && car) ? '/car/edit/' + car.car_id : '/car' %>" method="POST">
          <p class="p">Марка</p>
          <input type="text" id="brand" name="brand" required placeholder="Например, Toyota" value="<%= (typeof car !== 'undefined' && car) ? car.mark : '' %>">

          <p class="p">Модель</p>
          <input type="text" id="model" name="model" required placeholder="Например, Camry" value="<%= (typeof car !== 'undefined' && car) ? car.model : '' %>">

          <p class="p">Год выпуска</p>
          <input type="number" id="year" name="year" required min="1900" max="2099" placeholder="Например, 2020" value="<%= (typeof car !== 'undefined' && car) ? car.year : '' %>">

          <p class="p">Гос номер</p>
          <input type="text" id="registrationNumber" name="registrationNumber" required placeholder="А123БВ 82" value="<%= (typeof car !== 'undefined' && car) ? car.gos_nomer : '' %>">

          <p class="p">VIN номер</p>
          <input type="text" id="vin" name="vin" required placeholder="XTA00000000000000" value="<%= (typeof car !== 'undefined' && car) ? car.wincode : '' %>">

          <button type="submit" class="reg"><%= (typeof car !== 'undefined' && car) ? 'Сохранить изменения' : 'Зарегистрировать' %></button>
          <% if (typeof car !== 'undefined' && car) { %>
            <a href="/account" class="btn btn-login" style="margin-top: 10px; width: 100%; text-align: center; background: transparent; border: 1px solid var(--glass-border);">Отмена</a>
          <% } %>
        </form>
      </div>
    </div>
  </main>

  <script src="a6.js"></script>
</body>
</html>
